{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ValarAI",
  "colors": {
    "primary": "#2C4681",
    "light": "#8BA2DD",
    "dark": "#4F73C2"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": { "family": "Geist" },
    "body": { "family": "Geist" }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.valarhq.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start here",
            "icon": "flag",
            "pages": ["index", "quickstart", "models", "pricing"]
          },
          {
            "group": "Build agents",
            "icon": "robot",
            "pages": ["agents", "requests_at_scale", "opencode"]
          },
          {
            "group": "Inputs and adapters",
            "icon": "layer-group",
            "pages": ["images", "loras"]
          },
          {
            "group": "Run in production",
            "icon": "gauge-high",
            "pages": ["completion-windows", "webhooks", "idempotency"]
          },
          {
            "group": "Platform",
            "icon": "shield-halved",
            "pages": ["support", "dpa"]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "/openapi.json",
        "groups": [
          {
            "group": "Responses",
            "pages": [
              "api-reference/responses-api/create-a-response",
              "api-reference/responses-api/retrieve-a-response"
            ]
          },
          {
            "group": "Chat completions",
            "pages": ["api-reference/chat-completions-api/create-a-chat-completion"]
          },
          {
            "group": "Messages",
            "pages": ["api-reference/messages-api/create-an-anthropic-message"]
          },
          {
            "group": "Batches",
            "pages": [
              "api-reference/batches-api/list-batches",
              "api-reference/batches-api/create-a-batch",
              "api-reference/batches-api/get-batch-status",
              "api-reference/batches-api/get-batch-request-result"
            ]
          },
          {
            "group": "Models",
            "pages": ["api-reference/models-api/list-supported-models"]
          },
          {
            "group": "Usage",
            "pages": ["usage", "usage-endpoints"]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Overview",
            "pages": ["sdk-introduction", "sdk-configuration"]
          },
          {
            "group": "Traces",
            "pages": ["traces-sdk", "traces-sdk-inference", "traces-sdk-errors"]
          },
          {
            "group": "Integrations",
            "pages": ["sdk-tinker"]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/supported-models", "destination": "/models" }
  ]
}

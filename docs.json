{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ValarAI",
  "colors": {
    "primary": "#2C4681",
    "light": "#8BA2DD",
    "dark": "#4F73C2"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": { "family": "Geist" },
    "body": { "family": "Geist" }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.valarhq.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Inference",
            "icon": "bolt",
            "pages": [
              {
                "group": "Getting Started",
                "pages": ["index", "quickstart", "models", "pricing"]
              },
              {
                "group": "Platform",
                "pages": [
                  "completion-windows",
                  "webhooks",
                  "support",
                  "loras",
                  "images",
                  "idempotency"
                ]
              },
              {
                "group": "Guides",
                "pages": ["agents", "opencode", "requests_at_scale"]
              },
              {
                "group": "Security",
                "pages": ["dpa"]
              }
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Inference APIs",
            "openapi": "/openapi.json",
            "pages": [
              {
                "group": "Models API",
                "pages": ["api-reference/models-api/list-supported-models"]
              },
              {
                "group": "Responses API",
                "pages": [
                  "api-reference/responses-api/create-a-response",
                  "api-reference/responses-api/retrieve-a-response"
                ]
              },
              {
                "group": "Chat Completions API",
                "pages": ["api-reference/chat-completions-api/create-a-chat-completion"]
              },
              {
                "group": "Messages API",
                "pages": ["api-reference/messages-api/create-an-anthropic-message"]
              },
              {
                "group": "Batches API",
                "pages": [
                  "api-reference/batches-api/list-batches",
                  "api-reference/batches-api/create-a-batch",
                  "api-reference/batches-api/get-batch-status",
                  "api-reference/batches-api/get-batch-request-result"
                ]
              }
            ]
          },
          {
            "group": "Usage API",
            "pages": ["usage", "usage-endpoints"]
          },
          {
            "group": "ValarAI SDK",
            "pages": [
              "sdk-introduction",
              "sdk-configuration",
              {
                "group": "Traces",
                "pages": [
                  "traces-sdk",
                  "traces-sdk-inference",
                  "traces-sdk-errors"
                ]
              },
              "sdk-tinker"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/supported-models", "destination": "/models" }
  ]
}

{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Valar",
  "colors": {
    "primary": "#0F766E",
    "light": "#2DD4BF",
    "dark": "#15A394"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": { "family": "Inter Tight", "weight": 600 },
    "body": { "family": "Inter" }
  },
  "background": {
    "color": {
      "light": "#FBFEFE",
      "dark": "#0B1416"
    },
    "decoration": "grid"
  },
  "appearance": {
    "default": "system"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.valarhq.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "icon": "flag",
            "pages": [
              "index",
              "quickstart",
              "inference-modes",
              "models",
              "pricing"
            ]
          },
          {
            "group": "Build agents",
            "icon": "robot",
            "pages": [
              "agents",
              "structured-outputs",
              "requests_at_scale"
            ]
          },
          {
            "group": "Inputs and adapters",
            "icon": "layer-group",
            "pages": [
              "images"
            ],
            "hidden": true
          },
          {
            "group": "Run in production",
            "icon": "gauge-high",
            "pages": [
              "webhooks",
              "idempotency"
            ]
          },
          {
            "group": "Platform",
            "icon": "shield-halved",
            "pages": [
              "dpa",
              "support"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "/openapi.json",
        "groups": [
          {
            "group": "Responses",
            "pages": [
              "api-reference/responses-api/create-a-response",
              "api-reference/responses-api/retrieve-a-response"
            ]
          },
          {
            "group": "Chat completions",
            "pages": ["api-reference/chat-completions-api/create-a-chat-completion"]
          },
          {
            "group": "Batches",
            "pages": [
              "api-reference/batches-api/list-batches",
              "api-reference/batches-api/create-a-batch",
              "api-reference/batches-api/get-batch-status",
              "api-reference/batches-api/get-batch-request-result"
            ]
          },
          {
            "group": "Models",
            "pages": ["api-reference/models-api/list-supported-models"]
          },
          {
            "group": "Usage",
            "pages": ["usage", "usage-endpoints"]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/supported-models", "destination": "/models" },
    { "source": "/completion-windows", "destination": "/inference-modes#completion-windows" }
  ]
}
